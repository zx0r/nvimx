# .gitattributes - GitHub Linguist configuration
# This file tells GitHub how to categorize files and what to include in language statistics.

# --- Documentation & Metadata ---
# Mark all markdown and meta files as documentation to exclude them from code stats.
*.md linguist-documentation
LICENSE* linguist-documentation
CONTRIBUTING.md linguist-documentation
CHANGELOG.md linguist-documentation
docs/** linguist-documentation
prompts/** linguist-documentation
brain/** linguist-documentation

# --- Assets & Media ---
# Mark assets as vendored (binary/external) to keep them out of language breakdown.
assets/** linguist-vendored
*.gif linguist-vendored
*.png linguist-vendored
*.jpg linguist-vendored
*.svg linguist-vendored
*.mp4 linguist-vendored

# --- Configuration & Workspace Metadata ---
# Exclude config files and metadata from detection to reduce noise.
*.toml -linguist-detectable
*.lock -linguist-detectable
rust-toolchain.toml -linguist-detectable
config.example.toml linguist-documentation
dist-workspace.toml -linguist-detectable
.github/** -linguist-detectable

# --- Tool-Specific Data ---
# Exclude internal tool data for Gemini, Serena, etc.
.gemini/** -linguist-detectable
.serena/** -linguist-detectable

# --- Scripts & Installers ---
# Mark the installer script and completions as documentation/support.
nvimx-installer.sh linguist-documentation
assets/completions/** linguist-documentation

# --- Tests ---
# Exclude tests from language stats to focus on the project's core logic.
tests/** -linguist-detectable

# --- Generated & Backups ---
# Mark build artifacts and backup files as generated.
target/** linguist-generated
**/*.BAK linguist-generated
**/*.bak linguist-generated
